{
  "name": "@animespace/monorepo",
  "version": "0.1.0-beta.25",
  "private": true,
  "scripts": {
    "anime": "tsx apps/animespace/src/cli.ts",
    "build": "turbo run build --filter !@animespace/docs",
    "build:all": "turbo run build",
    "build:docs": "turbo run build --filter @animespace/docs",
    "dev:docs": "pnpm -C apps/docs dev",
    "format": "turbo run format --parallel",
    "release": "bumpp package.json apps/*/package.json packages/*/package.json --commit --push --tag",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck",
    "preversion": "pnpm test:ci"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260504.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/debug": "^4.1.13",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.2",
    "bumpp": "latest",
    "drizzle-kit": "0.31.10",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "turbo": "2.9.8",
    "typescript": "6.0.3",
    "unbuild": "3.6.1",
    "vitest": "4.1.5",
    "wrangler": "4.87.0"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=v24.0.0"
  }
}
